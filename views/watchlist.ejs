<%- include("./partials/nav.ejs") %>

<main class="media-page">
    <header class="media-page-header">
        <h1><%= user.username %>'s Watchlist</h1>
        <p>Your saved movies and TV shows.</p>
    </header>

    <% if (watchlist.length > 0) { %>
        <div class="watchlist-container">
            <% watchlist.forEach(media => { %>
                <a href="/<%= media.mediaType %>/<%= media.id %>">
                    <div class="movie-items">
                        <img class="home-poster" src="https://image.tmdb.org/t/p/w300<%= media.posterPath %>" alt="<%= media.title %>">

                        <div class="movie-text">
                            <span><%= media.title %></span>
                        </div>
                    </div>
                </a>
            <% }) %>
        </div>
    <% } else { %>
        <div class="empty-watchlist">
            <h2>Your watchlist is empty</h2>
            <p>Browse movies and TV shows and save something to watch later.</p>
            <a class="primary-button" href="/">Return Home</a>
        </div>
    <% } %>
</main>

</body>
</html>