<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CineTrack</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" type="image/png" href="/images/cinetrack-icon.png">
</head>

<body>
    <nav class="site-nav">
        <a class="site-nav-brand" href="/">
            <img src="/images/cinetrack-icon.png" alt="CineTrack logo">

            <span class="site-nav-name">
                <span class="cine-text">Cine</span><span class="track-text">Track</span>
            </span>
        </a>

        <form action="/browse" method="GET">
            <input type="search" name="search" required>
            <button type="submit">Search</button>
        </form>

        <div class="site-nav-links">
            <a class="site-nav-link" href="/">Home</a>

            <% if (user) { %>
                <a class="site-nav-link" href="/watchlist">Watchlist</a>

                <form class="site-nav-form" action="/auth/sign-out?_method=DELETE" method="POST">
                    <button class="primary-button site-nav-button" type="submit">
                        Sign Out
                    </button>
                </form>
                <% } else { %>
                    <a class="site-nav-link" href="/auth/sign-up">Sign Up</a>
                    <a class="site-nav-link" href="/auth/sign-in">Sign In</a>
                    <% } %>
        </div>
    </nav>