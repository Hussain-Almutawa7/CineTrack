<%- include("../partials/nav.ejs") %>

    <main>
        <section class="media-container" style="
            background-image:url('https://image.tmdb.org/t/p/original<%= movie.backdrop_path %>');
            ">
            <div class="media-details-container">
                <img class="media-details-poster" src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>"
                    alt="<%= movie.title %> ">

                <div class="media-details-content">
                    <h1>
                        <%= movie.title %>
                    </h1>
                    <p class="tagline">
                        <%= movie.tagline %>
                    </p>

                    <div class="media-info">
                        <% if(avgRating) { %>
                            <span>⭐ <%= avgRating %></span>
                        <% } else { %>
                            <span>⭐ Not Yet Rated</span>
                        <% } %>
                        <span>
                            <%= movie.release_date.slice(0, 4) || "Not available" %>
                        </span>
                        <span>
                            <%= movie.runtime %> min
                        </span>
                    </div>

                    <div class="genre">
                        <% movie.genres.forEach(genre=> { %>
                            <span class="genre-style">
                                <%= genre.name %>
                            </span>
                        <% }) %>
                    </div>

                    <h2>Overview</h2>
                    <p class="overview">
                        <%= movie.overview %>
                    </p>

                    <% if(user) { %>
                        <div class="media-actions">
                            <button class="primary-button">Add to Watchlist</button>

                            <div class="secondary-button">
                                <% if(userRating) {%>
                                    <button class="open-add-rating">Your Rating: <%= userRating.rating %>/10</button>
                                <% } else { %>
                                    <button class="open-add-rating">Rate Movie</button>
                                <% } %>

                                <% if(reviews.some(review => review.user.equals(user.id))) {%>
                                    <button class="open-add-review" disabled>Reviewed &#10004;</button>
                                <% } else { %>
                                        <button class="open-add-review">Add Review</button>
                                <% } %>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </section>

        <% if(user) {%>
            <dialog class="add-review">
                <form action="/movies/<%= movie.id %>/reviews" method="POST">
                    <div class="review-form-header">
                        <h2>Add Review</h2>
                        <button class="close-review" type="button">X</button>
                    </div>
                    <textarea name="comment" id="comment" required></textarea>

                    <div class="form-review-buttons">
                        <button class="cancel-review" type="button">Cancel</button>
                        <button class="primary-button submit-review" type="submit">Submit Review</button>
                    </div>
                </form>
            </dialog>

            <dialog class="add-rate">
                <form action="/movies/<%= movie.id %>/rating" method="POST">
                    <div class="review-form-header">
                        <h2><%= userRating? "Edit Rating" : "Add Rating" %></h2>
                        <button class="close-rate" type="button">X</button>
                    </div>

                     <div class="star-container">
                        <div class="star-rating">
                            <% for(let i = 10; i >= 1; i--) { %>
                                <input type="radio" name="rating" id="rating-<%= i %>" value="<%= i %>" <%= userRating && userRating.rating === i ? "checked" : "" %>  required>
                                <label for="rating-<%= i %>">&#9733;</label>
                            <% } %>
                        </div>
                        <p class="rating-info">Choose Rating from 1 to 10</p>
                     </div>

                    <div class="form-review-buttons">
                        <button class="cancel-rate" type="button">Cancel</button>
                        <button class="primary-button submit-rate" type="submit"><%= userRating? "Update Rating" : "Submit Rating" %></button>
                    </div>
                </form>
            </dialog>
        <% } %>

        <section class="display-review">
            <h2>User Reviews</h2>
            <% if(reviews.length === 0) { %>
                <p class="no-reviews">No Reviews yet</p>
            <%  } %>

            <% reviews.forEach(review => { %>
                <div class="specific-review">
                    <div class="specific-review-items">
                        <div class="profile-container">
                            <div class="profile-picture">
                                <span class="review-profile">
                                    <%= review.user.username.charAt(0).toUpperCase() %>
                                </span>
                            </div>
                            <div class="profile-info">
                                <strong>
                                    <%= review.user.username %>
                                </strong>
                                <p><%= review.user.createdAt.toLocaleDateString() %></p>
                            </div>
                        </div>
                
                        <% if(user && review.user.equals(user.id)) {%>
                            <div class="specific-review-buttons">
                                <button class="open-edit-review">Edit</button>
                                <form action="/movies/<%= movie.id %>/reviews/<%= review.id %>?_method=DELETE"
                                    method="POST">
                                    <button type="submit" class="delete-review">Delete</button>
                                </form>
                            </div>
                            <dialog class="edit-review">
                                <form action="/movies/<%= movie.id %>/reviews/<%= review.id %>?_method=PUT"
                                    method="POST">
                                    <div class="review-form-header">
                                        <h2>Edit Review</h2>
                                        <button class="close-edit-review" type="button">X</button>
                                    </div>
                                    <textarea name="comment" id="comment" required><%= review.comment %></textarea>

                                    <div class="form-review-buttons">
                                        <button class="cancel-edit-review" type="button">Cancel</button>
                                        <button class="primary-button submit-review" type="submit">Submit Review</button>
                                    </div>
                                </form>
                            </dialog>
                        <% } %>
                    </div>
                    <p class="review-comment"><%= review.comment %></p>
                </div>         
            <% }) %>
        </section>

    </main>
    <script src="/scripts/handle-dialog.js"></script>
    </body>

    </html>